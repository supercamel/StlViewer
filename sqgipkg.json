{
  "name": "StlViewer",
  "app_id": "io.github.sam.StlViewer",
  "icon": "images/io.github.sam.StlViewer.png",
  "desktop_terminal": false,
  "desktop_categories": [
    "Graphics",
    "GTK"
  ],
  "script": "main.nut",
  "target": "appimage",
  "sqgi_source": {
    "repo": "https://github.com/supercamel/sqgi.git",
    "ref": "3a5051af8aa8485a3ed0e2596b46ef2182bd1d81"
  },
  "resources": [
    "examples",
    "images/io.github.sam.StlViewer.png"
  ],
  "native_projects": [
    {
      "name": "stlviewer-native",
      "dir": "native",
      "build": [
        "./build.sh"
      ],
      "libraries": [
        "build/libstlviewer-1.0.so"
      ],
      "typelibs": [
        "build/StlViewer-1.0.typelib"
      ]
    }
  ],
  "linux": {
    "arches": [
      {
        "arch": "x86_64",
        "build_dir": "build-linux-x86_64",
        "inherit_native_projects": false,
        "deb": {
          "download": true,
          "suite": "noble",
          "packages": [
            "libgtk-4-1",
            "gir1.2-gtk-4.0",
            "libglib2.0-0",
            "libgirepository-1.0-1",
            "libharfbuzz-gobject0",
            "libepoxy0",
            "libepoxy-dev"
          ]
        },
        "build": [
          "cmake -E rm -rf \"$SQGI_LINUX_BUILD_DIR\"",
          "cmake -S \"$SQGI_SOURCE_DIR\" -B \"$SQGI_LINUX_BUILD_DIR\" -G Ninja ${SQGI_LINUX_CMAKE_TOOLCHAIN:+-DCMAKE_TOOLCHAIN_FILE=\"$SQGI_LINUX_CMAKE_TOOLCHAIN\"} -DCMAKE_BUILD_TYPE=Release -DSQ_ENABLE_JIT=ON",
          "cmake --build \"$SQGI_LINUX_BUILD_DIR\""
        ],
        "native_projects": [
          {
            "name": "stlviewer-native",
            "dir": "native",
            "build": [
              "BUILD_DIR=build-linux-x86_64 MESON_CROSS_FILE=\"$SQGI_LINUX_MESON_CROSS_FILE\" ./build.sh"
            ],
            "libraries": [
              "build-linux-x86_64/libstlviewer-1.0.so"
            ],
            "typelibs": [
              "build-linux-x86_64/StlViewer-1.0.typelib"
            ]
          }
        ]
      },
      {
        "arch": "aarch64",
        "build_dir": "build-linux-aarch64",
        "inherit_native_projects": false,
        "deb": {
          "download": true,
          "suite": "noble",
          "packages": [
            "libgtk-4-1",
            "gir1.2-gtk-4.0",
            "libglib2.0-0",
            "libgirepository-1.0-1",
            "libharfbuzz-gobject0",
            "libepoxy0",
            "libepoxy-dev"
          ]
        },
        "build": [
          "cmake -E rm -rf \"$SQGI_LINUX_BUILD_DIR\"",
          "cmake -S \"$SQGI_SOURCE_DIR\" -B \"$SQGI_LINUX_BUILD_DIR\" -G Ninja ${SQGI_LINUX_CMAKE_TOOLCHAIN:+-DCMAKE_TOOLCHAIN_FILE=\"$SQGI_LINUX_CMAKE_TOOLCHAIN\"} -DCMAKE_BUILD_TYPE=Release -DSQ_ENABLE_JIT=ON",
          "cmake --build \"$SQGI_LINUX_BUILD_DIR\""
        ],
        "native_projects": [
          {
            "name": "stlviewer-native",
            "dir": "native",
            "build": [
              "env -i PATH=/usr/bin:/bin HOME=\"$HOME\" BUILD_DIR=build-host ./build.sh",
              "BUILD_DIR=build-linux-aarch64 MESON_CROSS_FILE=\"$SQGI_LINUX_MESON_CROSS_FILE\" MESON_OPTIONS=\"-Dgenerate_gir=false\" ./build.sh"
            ],
            "libraries": [
              "build-linux-aarch64/libstlviewer-1.0.so"
            ],
            "typelibs": [
              "build-host/StlViewer-1.0.typelib"
            ]
          }
        ]
      }
    ]
  },
  "windows": {
    "msys2_prefix": "mingw64",
    "gdk_backend": "win32",
    "build_dir": "build-windows-x86_64",
    "packages": [
      "mingw-w64-x86_64-libepoxy"
    ],
    "files": [
      "images/io.github.sam.StlViewer.png=share/icons/hicolor/256x256/apps/io.github.sam.StlViewer.png"
    ],
    "build": [
      "cmake -E rm -rf \"$SQGI_WINDOWS_BUILD_DIR\"",
      "cmake -S \"$SQGI_SOURCE_DIR\" -B \"$SQGI_WINDOWS_BUILD_DIR\" -G Ninja -DCMAKE_TOOLCHAIN_FILE=\"$SQGI_WIN_CMAKE_TOOLCHAIN\" -DCMAKE_BUILD_TYPE=Release -DSQ_ENABLE_JIT=ON",
      "cmake --build \"$SQGI_WINDOWS_BUILD_DIR\" --target sqgi sqgi-bin"
    ],
    "native_projects": [
      {
        "name": "stlviewer-native",
        "dir": "native",
        "build": [
          "BUILD_DIR=build-windows-x86_64 MESON_CROSS_FILE=\"$SQGI_MESON_CROSS_FILE\" MESON_OPTIONS=\"-Dgenerate_gir=false\" ./build.sh",
          "env -i PATH=/usr/bin:/bin HOME=\"$HOME\" BUILD_DIR=build-host ./build.sh",
          "sed 's/shared-library=\"libstlviewer-1.0.so\"/shared-library=\"libstlviewer-1.0.dll\"/' build-host/StlViewer-1.0.gir > build-windows-x86_64/StlViewer-1.0.gir",
          "g-ir-compiler build-windows-x86_64/StlViewer-1.0.gir --output build-windows-x86_64/StlViewer-1.0.typelib"
        ],
        "libraries": [
          "build-windows-x86_64/libstlviewer-1.0.dll"
        ],
        "typelibs": [
          "build-windows-x86_64/StlViewer-1.0.typelib"
        ]
      }
    ],
    "nsis_options": {
      "icon": "images/stlviewer.ico"
    }
  }
}
